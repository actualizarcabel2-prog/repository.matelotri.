<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="repository.addons.matelotri" name="Addons Matelotri" version="1.0.0" provider-name="Matelotri">
    <extension point="xbmc.addon.repository" name="Addons Matelotri">
        <dir>
            <info compressed="false">https://actualizarcabel2-prog.github.io/addons-matelotri/addons.xml</info>
            <checksum>https://actualizarcabel2-prog.github.io/addons-matelotri/addons.xml.md5</checksum>
            <datadir zip="true">https://actualizarcabel2-prog.github.io/addons-matelotri/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <platform>all</platform>
        <summary lang="es_ES">Repositorio de Addons Matelotri</summary>
        <description lang="es_ES">Repositorio oficial de addons Matelotri Cinema para Kodi.</description>
    </extension>
</addon>

<addon id="skin.matelotri"
       version="1.0.0"
       name="Matelotri"
       provider-name="Matelotri Team">
  <requires>
    <import addon="xbmc.gui" version="5.17.0"/>
    <import addon="script.skinshortcuts" version="1.1.1" optional="true"/>
  </requires>
  <extension point="xbmc.gui.skin"
             debugging="false"
             defaultresolution="1080i"
             defaultresolutionwide="1080i"
             effectslowdown="1.00"
             defaultthemename="default">
    <res width="1920" height="1080" aspect="16:9" default="true" folder="1080i"/>
  </extension>
  <extension point="xbmc.addon.metadata">
    <platform>all</platform>
    <summary lang="en_GB">Matelotri - Premium Streaming Skin</summary>
    <summary lang="es_ES">Matelotri - Skin Premium de Streaming</summary>
    <description lang="en_GB">Matelotri is a premium 4K skin designed for Android TV boxes. Features a modern streaming platform design with cinematic aesthetics, smooth animations, and full Yatse remote control compatibility including voice search. Inspired by the best modern skins with an original Matelotri identity.</description>
    <description lang="es_ES">Matelotri es un skin premium 4K diseñado para Android TV boxes. Cuenta con un diseño moderno de plataforma de streaming con estética cinematográfica, animaciones suaves y compatibilidad total con el control remoto Yatse, incluyendo búsqueda por voz. Inspirado en los mejores skins modernos con una identidad Matelotri original.</description>
    <disclaimer lang="en_GB">Matelotri Skin - For personal use only</disclaimer>
    <disclaimer lang="es_ES">Skin Matelotri - Solo para uso personal</disclaimer>
    <license>GPL-2.0-only</license>
    <assets>
      <icon>resources/icon.png</icon>
      <fanart>resources/fanart.png</fanart>
    </assets>
  </extension>
</addon>

<addon id="plugin.video.matelotricinema" name="[COLOR gold]Matelotri Cinema[/COLOR]" version="1.0.5" provider-name="Matelotri">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="default.py">
    <provides>video</provides>
  </extension>
  <extension point="xbmc.addon.metadata">
    <description lang="es_ES">Matelotri Cinema - Tu cine en casa. Películas, Series, Anime y más.</description>
    <platform>all</platform>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.png</fanart>
    </assets>
  </extension>
</addon>

<addon id="plugin.program.matelotriwizard" name="Matelotri Wizard" version="3.0.0" provider-name="Agustin">
    <requires>
        <import addon="xbmc.python" version="3.0.0" />
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" start="startup" />
    <extension point="xbmc.addon.metadata">
        <summary lang="es_ES">Matelotri Wizard - Tu cine en casa</summary>
        <summary lang="en_GB">Matelotri Wizard - Your home cinema</summary>
        <description lang="es_ES">Centro de control Matelotri. Instala, configura y mantiene tu experiencia cinematografica perfecta.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.png</fanart>
        </assets>
    </extension>
</addon>

</addons>
